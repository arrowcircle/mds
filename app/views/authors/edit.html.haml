.h-full.w-full.max-w-xl.mx-auto.align-middle
  %h1.text-center.pt-8
    - if @author.persisted?
      Редактировать автора
    - else
      Добавить автора
  = form_with model: @author, class: "rounded-box border border-base-300 bg-base-100 p-4 shadow-sm sm:p-6 mb-4" do |f|

    - if @author.errors.any?
      .mb-4
        %span Ошибки при сохранении: #{@author.errors.size}
        %ul.list-disc.pl-4
          - @author.errors.each do |error|
            %li= error.full_message

    - label_classes = "block text-sm font-bold mb-2 #{alert ? "text-error" : ""}"
    - input_classes = "input input-bordered w-full #{alert ? "input-error" : nil}"
    - textarea_classes = "textarea textarea-bordered min-h-32 w-full #{alert ? "textarea-error" : nil}"
    - file_classes = "file-input file-input-bordered w-full"

    .mb-4
      = f.label :name, "Имя", class: label_classes
      = f.text_field :name, autofocus: true, autocomplete: :off, class: input_classes, placeholder: "Имя автора"
    .mb-4
      = f.label :image, "Изображение", class: label_classes
      - if @author.image.present?
        = vite_image_tag @author.image.imgproxy_url(width: 100, resizing_type: :fill)
      = f.hidden_field :image, value: @author.cached_image_data
      = f.file_field :image, class: file_classes
    .mb-4
      = f.label :description, "Описание", class: label_classes
      = f.text_area :description, autocomplete: :off, class: textarea_classes, placeholder: "Описание"
    = f.submit "Сохранить", class: "btn btn-primary"
    = link_to "Назад", :back, class: "btn btn-neutral"
