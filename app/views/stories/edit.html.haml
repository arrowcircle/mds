.h-full.w-full.max-w-xl.mx-auto.align-middle
  %h1.text-center.pt-8
    - if @story.persisted?
      Редактировать рассказ
    - else
      Добавить рассказ

  = form_with model: [@author, @story], class: "rounded-box border border-base-300 bg-base-100 p-4 shadow-sm sm:p-6 mb-4" do |f|
    - if @story.errors.any?
      .mb-4
        %span Ошибки при сохранении: #{@story.errors.size}
        %ul.list-disc.pl-4
          - @story.errors.each do |error|
            %li= error.full_message

    - label_classes = "block text-sm font-bold mb-2 #{alert ? "text-error" : ""}"
    - input_classes = "input input-bordered w-full #{alert ? "input-error" : nil}"
    - select_classes = "select select-bordered w-full #{alert ? "select-error" : nil}"
    - date_select_classes = "select select-bordered w-auto max-w-full #{alert ? "select-error" : nil}"
    - textarea_classes = "textarea textarea-bordered min-h-32 w-full #{alert ? "textarea-error" : nil}"
    - file_classes = "file-input file-input-bordered w-full"

    .mb-4
      = f.label :name, "Название", class: label_classes
      = f.text_field :name, autofocus: true, autocomplete: :off, class: input_classes, placeholder: "Название рассказа"
    - if current_user.admin?
      .mb-4
        = f.label :image, "Изображение", class: label_classes
        - if @story.image.present?
          = vite_image_tag @story.image.imgproxy_url(width: 100, resizing_type: :fill)
        = f.hidden_field :image, value: @story.cached_image_data
        = f.file_field :image, class: file_classes
      .mb-4
        = f.label :radio, "Место", class: label_classes
        = f.select :radio, options_for_select(Story.radios.map {|key, value| [Story.human_enum_name(:radios, key), key.to_sym]}, selected: @story.radio), { include_blank: "Не выбрано" }, { class: select_classes }
      .mb-4
        = f.label :date, class: label_classes
        = f.date_select :date, { start_year: 1995, end_year: Date.today.year }, { class: date_select_classes }
      .mb-4
        = f.label :description, "Описание", class: label_classes
        = f.text_area :description, autocomplete: :off, class: textarea_classes, placeholder: "Введите описание"
      .mb-4.flex.flex-row.items-center.gap-1
        = f.check_box :completed, class: :checkbox
        = f.label :completed, "Опознан полностью?"
      .mb-4
        = f.label :external_audio_url, class: label_classes
        = f.text_field :external_audio_url, class: input_classes, placeholder: "Внешняя ссылка на mp3. Чтобы можно было слушать на сайте"
      .mb-4
        = f.hidden_field :audio, value: @story.cached_audio_data, id: nil
        = f.label :audio, class: label_classes
        - if @story.audio.present?
          = @story.audio.metadata["filename"]
        = f.file_field :audio, class: file_classes, placeholder: "Аудио файл"

    = f.submit "Сохранить", class: "btn btn-primary"
    = link_to "Назад", [@author, @story], class: "btn btn-neutral"
